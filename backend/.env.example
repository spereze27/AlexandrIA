# ─── Copy to .env and fill in values ─────────────────────────────────────────

ENVIRONMENT=dev
DEBUG=true

# Database (local PostgreSQL)
DB_HOST=localhost
DB_NAME=formbuilder
DB_USER=formbuilder_app
DB_PASSWORD=localdevpassword

# Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# JWT
JWT_SECRET=local-dev-secret-change-in-production-please
JWT_EXPIRE_MINUTES=10080

# Google Sheets (base64-encoded service account JSON)
GOOGLE_SHEETS_SA_KEY=

# Cloud Storage (use local emulator or real bucket)
GCS_BUCKET_NAME=formbuilder-media-dev

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
