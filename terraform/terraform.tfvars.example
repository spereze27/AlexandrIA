# ─── Terraform variables ────────────────────────────────────────────────────
# Copy to terraform.tfvars and fill in. NEVER commit terraform.tfvars to git!
#
# NOTA: Las API keys (Gemini, Maps, OAuth) NO van aquí.
# Se almacenan en GitHub Secrets y se inyectan en Cloud Run al hacer deploy.
# ─────────────────────────────────────────────────────────────────────────────

project_id  = "your-gcp-project-id"
region      = "us-central1"
environment = "prod"

# Cloud SQL
db_tier = "db-f1-micro"    # Usa db-custom-1-3840 para producción
db_name = "formbuilder"
db_user = "formbuilder_app"

# Cloud Run (dejar vacío, CI/CD maneja las imágenes)
backend_image         = ""
frontend_image        = ""
backend_cpu           = "1"
backend_memory        = "512Mi"
backend_max_instances = 5
